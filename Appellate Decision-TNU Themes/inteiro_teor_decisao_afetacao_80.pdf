<script language="Javascript" src="funcao.js"></script>
<script type="text/javascript">
	function trim(nome){
		tam = nome.length;
		ini=0;
		fim=0;
		for (i=0 ; i<tam ; i++){
			elem = nome.charAt(i);   
			if (elem==" ") ini=ini+1;
			else break;
		}
		for (i=1 ; i<tam ; i++){
			elem = nome.charAt(tam-i);   
			if (elem==" ") fim=fim+1;
			else break;
		}
		if (fim!=0) 
			return nome.slice(ini,-fim);  
		else 
			return nome.substr(ini)
	}
	
	
	function limpa(){
		document.frmPesquisa.tipo.options[0].selected = true;
		document.frmPesquisa.pesq.value=""; 
		document.frmPesquisa.pesq.focus();
	}
	
	//Funcao para validar os critérios de pesquisa
	function valida_campos(){
		tipo = document.frmPesquisa.tipo.value;
		document.frmPesquisa.pesq.value = trim(document.frmPesquisa.pesq.value.toUpperCase());
		valor = document.frmPesquisa.pesq.value;
	
	
		if (tipo==""){
			alert("Escolha um dos campos abaixo correspondente ao critério de pesquisa desejado.");
			return false;			
		}
		//critica do número do processo
	
		if (trim(valor)==""){
			alert("Digite o texto para pesquisa.");
			document.frmPesquisa.pesq.focus();
			return false;			
		}
	
	
		if (tipo == "num_pro"){
			if (!validarDVNumProces(document.frmPesqdistribui.num_proces.value))
		   {
			 alert("Número de processo inválido!");
			 document.frmPesqdistribui.num_proces.focus();
			 return false;
		   }
			if (isnumeric(document.frmPesquisa.pesq) == 0){
				alert("Somente número é válido!, Ex.: 200270000307060");
				document.frmPesquisa.pesq.focus();
				return false; 
			}
		}	
		return true;
	}
	
	//verifica se o campo é numerico
	function isnumeric(field){
		var valid = "0123456789"
		var ok = "yes"; 
		var temp;
		for (var i=0; i<field.value.length; i++){
			temp = "" + field.value.substring(i, i+1);
			if (valid.indexOf(temp) == "-1")
			ok = "no";
		} 
		if (ok == "no"){
			return 0;
		}else{
			return 1;
		}  
	} 
</script>
