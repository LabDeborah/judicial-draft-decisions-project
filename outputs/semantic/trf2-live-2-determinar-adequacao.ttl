@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix tcc: <https://example.org/tcc/ontology#> .

<https://example.org/tcc/run/run-20260604t121316z> a prov:Activity, tcc:PipelineRun .

<https://example.org/tcc/agent/pipeline> a prov:Agent, tcc:SoftwarePipeline .

<https://example.org/tcc/agent/local-text-similarity> a prov:Agent, tcc:LocalClassifier ;
  dcterms:title "local-text-similarity" ;
  tcc:analysisStrategy "local" .

<https://example.org/tcc/decision/trf2-live-2> a tcc:LegalDecision, prov:Entity ;
  tcc:decisionId "TRF2-LIVE-2" ;
  tcc:numeroProcesso "5028717-34.2024.4.02.5001" ;
  tcc:assuntos "DIREITO PREVIDENCIÁRIO. APELAÇÃO. BENEFÍCIOS POR INCAPACIDADE. AUSÊNCIA DE INCAPACIDADE LABORATIVA CONSTATADA EM PERÍCIA JUDICIAL. RECURSO DESPROVIDO. I. Caso em exame Apelação contra sentença que julgou improcedente pedido de concessão de auxílio-doença, com posterior conversão em aposentadoria por invalidez , sob fundamento de inexistência de incapacidade laborativa atestada em perícia judicial. II. Questão em disc" .

<https://example.org/tcc/theme/1> a tcc:TnuTheme, prov:Entity ;
  tcc:temaNumero "1" ;
  tcc:teseFirmada "O valor da aposentadoria por invalidez e do auxílio-doença, bem como das pensões destes derivados ou calculadas com base no art. 75, da Lei n. 8.213/91, será obtido, na forma do art. 29, II, do mesmo diploma, por meio da média aritmética simples dos 80% maiores salários de contribuição, considerado todo o período contributivo, independentemente do momento de inscrição do segurado e do número de contribuições mensais do período contributivo." .

<https://example.org/tcc/activity/classification-trf2-live-2> a prov:Activity, tcc:ClassificationActivity ;
  prov:used <https://example.org/tcc/decision/trf2-live-2>, <https://example.org/tcc/theme/1> ;
  prov:generated <https://example.org/tcc/analysis/trf2-live-2> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/local-text-similarity> ;
  prov:wasInformedBy <https://example.org/tcc/run/run-20260604t121316z> .

<https://example.org/tcc/analysis/trf2-live-2> a tcc:AnalysisResult, prov:Entity ;
  tcc:temaTnu "1" ;
  tcc:consonancia "DISSONANCIA" ;
  tcc:validade "VALIDA" ;
  tcc:justificativa "Tema 1 selecionado por semelhanca de assunto." ;
  tcc:aboutDecision <https://example.org/tcc/decision/trf2-live-2> ;
  tcc:aboutTheme <https://example.org/tcc/theme/1> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/classification-trf2-live-2> .

<https://example.org/tcc/activity/draft-generation-trf2-live-2> a prov:Activity, tcc:DraftGenerationActivity ;
  prov:used <https://example.org/tcc/analysis/trf2-live-2>, <https://example.org/tcc/decision/trf2-live-2>, <https://example.org/tcc/theme/1> ;
  prov:generated <https://example.org/tcc/draft/trf2-live-2-determinar-adequacao> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/pipeline> ;
  prov:wasInformedBy <https://example.org/tcc/activity/classification-trf2-live-2> .

<https://example.org/tcc/draft/trf2-live-2-determinar-adequacao> a tcc:LegalDraft, prov:Entity ;
  tcc:action "DETERMINAR_ADEQUACAO" ;
  tcc:texPath "outputs/documents/TRF2-LIVE-2-DETERMINAR_ADEQUACAO.tex" ;
  tcc:pdfPath "outputs/documents/TRF2-LIVE-2-DETERMINAR_ADEQUACAO.pdf" ;
  tcc:generatedFromDecision <https://example.org/tcc/decision/trf2-live-2> ;
  tcc:generatedFromAnalysis <https://example.org/tcc/analysis/trf2-live-2> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/draft-generation-trf2-live-2> .
