@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix tcc: <https://example.org/tcc/ontology#> .

<https://example.org/tcc/run/run-20260604t135251z> a prov:Activity, tcc:PipelineRun .

<https://example.org/tcc/agent/pipeline> a prov:Agent, tcc:SoftwarePipeline .

<https://example.org/tcc/agent/local-text-similarity> a prov:Agent, tcc:LocalClassifier ;
  dcterms:title "local-text-similarity" ;
  tcc:analysisStrategy "local" .

<https://example.org/tcc/decision/trf2-live-7> a tcc:LegalDecision, prov:Entity ;
  tcc:decisionId "TRF2-LIVE-7" ;
  tcc:numeroProcesso "5096650-15.2024.4.02.5101" ;
  tcc:assuntos "DIREITO PREVIDENCIÁRIO E PROCESSUAL CIVIL. APELAÇÃO CÍVEL. APOSENTADORIA POR IDADE URBANA. CONTAGEM RECÍPROCA. CERTIDÃO DE TEMPO DE CONTRIBUIÇÃO (CTC). FALTA DE INTERESSE DE AGIR. RECURSO PARCIALMENTE PROVIDO. I. CASO EM EXAME 1. Apelação interposta contra sentença que julgou improcedente o pedido de aposentadoria por idade urbana, sob o fundamento de que a segurada não apresentou a Certidão de Tempo de Contribuição " .

<https://example.org/tcc/theme/2> a tcc:TnuTheme, prov:Entity ;
  tcc:temaNumero "2" ;
  tcc:teseFirmada "No caso de aposentadoria por idade rural, a certidão de casamento vale como início de prova material, ainda que extemporânea." .

<https://example.org/tcc/activity/classification-trf2-live-7> a prov:Activity, tcc:ClassificationActivity ;
  prov:used <https://example.org/tcc/decision/trf2-live-7>, <https://example.org/tcc/theme/2> ;
  prov:generated <https://example.org/tcc/analysis/trf2-live-7> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/local-text-similarity> ;
  prov:wasInformedBy <https://example.org/tcc/run/run-20260604t135251z> .

<https://example.org/tcc/analysis/trf2-live-7> a tcc:AnalysisResult, prov:Entity ;
  tcc:temaTnu "2" ;
  tcc:consonancia "DISSONANCIA" ;
  tcc:validade "VALIDA" ;
  tcc:justificativa "Tema 2 selecionado por semelhanca de assunto." ;
  tcc:aboutDecision <https://example.org/tcc/decision/trf2-live-7> ;
  tcc:aboutTheme <https://example.org/tcc/theme/2> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/classification-trf2-live-7> .

<https://example.org/tcc/activity/draft-generation-trf2-live-7> a prov:Activity, tcc:DraftGenerationActivity ;
  prov:used <https://example.org/tcc/analysis/trf2-live-7>, <https://example.org/tcc/decision/trf2-live-7>, <https://example.org/tcc/theme/2> ;
  prov:generated <https://example.org/tcc/draft/trf2-live-7-determinar-adequacao> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/pipeline> ;
  prov:wasInformedBy <https://example.org/tcc/activity/classification-trf2-live-7> .

<https://example.org/tcc/draft/trf2-live-7-determinar-adequacao> a tcc:LegalDraft, prov:Entity ;
  tcc:action "DETERMINAR_ADEQUACAO" ;
  tcc:texPath "outputs/documents/TRF2-LIVE-7-DETERMINAR_ADEQUACAO.tex" ;
  tcc:pdfPath "outputs/documents/TRF2-LIVE-7-DETERMINAR_ADEQUACAO.pdf" ;
  tcc:generatedFromDecision <https://example.org/tcc/decision/trf2-live-7> ;
  tcc:generatedFromAnalysis <https://example.org/tcc/analysis/trf2-live-7> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/draft-generation-trf2-live-7> .
