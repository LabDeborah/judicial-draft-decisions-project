@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix tcc: <https://example.org/tcc/ontology#> .

<https://example.org/tcc/run/run-20260604t121424z> a prov:Activity, tcc:PipelineRun .

<https://example.org/tcc/agent/pipeline> a prov:Agent, tcc:SoftwarePipeline .

<https://example.org/tcc/agent/gemini-flash-lite-latest> a prov:Agent, tcc:LargeLanguageModel ;
  dcterms:title "gemini-flash-lite-latest" ;
  tcc:analysisStrategy "gemini" .

<https://example.org/tcc/decision/trf2-live-13> a tcc:LegalDecision, prov:Entity ;
  tcc:decisionId "TRF2-LIVE-13" ;
  tcc:numeroProcesso "5001069-45.2021.4.02.5111" ;
  tcc:assuntos "PREVIDENCIÁRIO. APOSENTADORIA POR TEMPO DE CONTRIBUIÇÃO. CONVERSÃO DE TEMPO ESPECIAL EM TEMPO COMUM. POSSIBILIDADE. EXPOSIÇÃO A AGENTES NOCIVOS. PROVA. PPP. LEGISLAÇÃO VIGENTE À ÉPOCA DA EXPOSIÇÃO. POSSIBILIDADE DE LAUDO EXTEMPORÂNEO. FATOR DE CONVERSÃO. LEGISLAÇÃO VIGENTE À ÉPOCA DA CONCESSÃO DO BENEFÍCIO. JUROS E CORREÇÃO MONETÁRIA. POSSIBILIDADE DE CONHECIMENTO DE OFÍCIO. TEMAS 905 DO STJ E 810 DO STF. INCIDÊNCIA " .

<https://example.org/tcc/theme/14> a tcc:TnuTheme, prov:Entity ;
  tcc:temaNumero "14" ;
  tcc:teseFirmada "Na aposentadoria especial a apresentação de laudo pericial extemporâneo não afasta sua força probante, desde que não modificadas as condições do ambiente. Vide Súmula 68 da TNU." .

<https://example.org/tcc/activity/classification-trf2-live-13> a prov:Activity, tcc:ClassificationActivity ;
  prov:used <https://example.org/tcc/decision/trf2-live-13>, <https://example.org/tcc/theme/14> ;
  prov:generated <https://example.org/tcc/analysis/trf2-live-13> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/gemini-flash-lite-latest> ;
  prov:wasInformedBy <https://example.org/tcc/run/run-20260604t121424z> .

<https://example.org/tcc/analysis/trf2-live-13> a tcc:AnalysisResult, prov:Entity ;
  tcc:temaTnu "14" ;
  tcc:consonancia "CONSONANCIA" ;
  tcc:validade "VALIDA" ;
  tcc:justificativa "A decisão judicial aborda a possibilidade de utilização de laudo extemporâneo para a comprovação de tempo especial, alinhando-se perfeitamente à tese firmada no Tema 14 da TNU e à Súmula 68 da TNU. | Resultado reutilizado do cache Gemini." ;
  tcc:aboutDecision <https://example.org/tcc/decision/trf2-live-13> ;
  tcc:aboutTheme <https://example.org/tcc/theme/14> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/classification-trf2-live-13> .

<https://example.org/tcc/activity/draft-generation-trf2-live-13> a prov:Activity, tcc:DraftGenerationActivity ;
  prov:used <https://example.org/tcc/analysis/trf2-live-13>, <https://example.org/tcc/decision/trf2-live-13>, <https://example.org/tcc/theme/14> ;
  prov:generated <https://example.org/tcc/draft/trf2-live-13-negar-seguimento> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/pipeline> ;
  prov:wasInformedBy <https://example.org/tcc/activity/classification-trf2-live-13> .

<https://example.org/tcc/draft/trf2-live-13-negar-seguimento> a tcc:LegalDraft, prov:Entity ;
  tcc:action "NEGAR_SEGUIMENTO" ;
  tcc:texPath "outputs/documents/TRF2-LIVE-13-NEGAR_SEGUIMENTO.tex" ;
  tcc:pdfPath "outputs/documents/TRF2-LIVE-13-NEGAR_SEGUIMENTO.pdf" ;
