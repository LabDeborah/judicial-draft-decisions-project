@prefix tcc: <https://example.org/tcc/ontology#> .

<https://example.org/tcc/run/run-20260604t134756z> a prov:Activity, tcc:PipelineRun .

<https://example.org/tcc/agent/pipeline> a prov:Agent, tcc:SoftwarePipeline .

<https://example.org/tcc/agent/gemini-flash-lite-latest> a prov:Agent, tcc:LargeLanguageModel ;
  dcterms:title "gemini-flash-lite-latest" ;
  tcc:analysisStrategy "gemini" .

<https://example.org/tcc/decision/trf2-live-17> a tcc:LegalDecision, prov:Entity ;
  tcc:decisionId "TRF2-LIVE-17" ;
  tcc:numeroProcesso "5009544-90.2021.4.02.5110" ;
  tcc:assuntos "EMENTA1: DIREITO PREVIDENCIÁRIO. RECURSO DE APELAÇÃO. RECONHECIMENTO DE TEMPO DE SERVIÇO ESPECIAL. PARCIAL PROVIMENTO. I. CASO EM EXAME 1. Recurso de apelação interposto contra sentença que julgou parcialmente procedente o pedido. O recorrente busca a anulação da sentença por cerceamento de defesa, alegando ausência de prova pericial referente ao labor nas empresas Tall Max e GP Indústria Mecânica Ltda. Subsidiariame" .

<https://example.org/tcc/theme/14> a tcc:TnuTheme, prov:Entity ;
  tcc:temaNumero "14" ;
  tcc:teseFirmada "Na aposentadoria especial a apresentação de laudo pericial extemporâneo não afasta sua força probante, desde que não modificadas as condições do ambiente. Vide Súmula 68 da TNU." .

<https://example.org/tcc/activity/classification-trf2-live-17> a prov:Activity, tcc:ClassificationActivity ;
  prov:used <https://example.org/tcc/decision/trf2-live-17>, <https://example.org/tcc/theme/14> ;
  prov:generated <https://example.org/tcc/analysis/trf2-live-17> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/gemini-flash-lite-latest> ;
  prov:wasInformedBy <https://example.org/tcc/run/run-20260604t134756z> .

<https://example.org/tcc/analysis/trf2-live-17> a tcc:AnalysisResult, prov:Entity ;
  tcc:temaTnu "14" ;
  tcc:consonancia "CONSONANCIA" ;
  tcc:validade "VALIDA" ;
  tcc:justificativa "A decisão trata de reconhecimento de tempo especial e menciona a necessidade de prova pericial, alinhando-se ao entendimento do Tema 14 da TNU, que estabelece que laudos extemporâneos não afastam a força probatória das condições especiais de trabalho, desde que as condições ambientais não tenham sido alteradas. | Resultado reutilizado do cache Gemini." ;
  tcc:aboutDecision <https://example.org/tcc/decision/trf2-live-17> ;
  tcc:aboutTheme <https://example.org/tcc/theme/14> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/classification-trf2-live-17> .

<https://example.org/tcc/activity/draft-generation-trf2-live-17> a prov:Activity, tcc:DraftGenerationActivity ;
  prov:used <https://example.org/tcc/analysis/trf2-live-17>, <https://example.org/tcc/decision/trf2-live-17>, <https://example.org/tcc/theme/14> ;
