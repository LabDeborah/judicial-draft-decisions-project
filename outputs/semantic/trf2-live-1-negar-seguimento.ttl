@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix tcc: <https://example.org/tcc/ontology#> .

<https://example.org/tcc/run/run-20260604t135935z> a prov:Activity, tcc:PipelineRun .

<https://example.org/tcc/agent/pipeline> a prov:Agent, tcc:SoftwarePipeline .

<https://example.org/tcc/agent/gemini-flash-lite-latest> a prov:Agent, tcc:LargeLanguageModel ;
  dcterms:title "gemini-flash-lite-latest" ;
  tcc:analysisStrategy "gemini" .

<https://example.org/tcc/decision/trf2-live-1> a tcc:LegalDecision, prov:Entity ;
  tcc:decisionId "TRF2-LIVE-1" ;
  tcc:numeroProcesso "5000632-45.2025.4.02.9999" ;
  tcc:assuntos "DIREITO PREVIDENCIÁRIO. APELAÇÃO CÍVEL. APOSENTADORIA POR IDADE RURAL. SEGURADO ESPECIAL. RECURSO DESPROVIDO. I. Caso em exame 1. Apelação cível interposta pelo INSS contra sentença que concedeu aposentadoria por idade rural a segurado especial, reconhecendo o exercício de atividade campesina no período de carência anterior ao requerimento administrativo. II. Questão em discussão 2. A questão em discussão consiste em" .

<https://example.org/tcc/theme/5> a tcc:TnuTheme, prov:Entity ;
  tcc:temaNumero "5" ;
  tcc:teseFirmada "Para a obtenção de aposentadoria por idade rural, é indispensável o exercício e a demonstração da atividade campesina correspondente à carência no período imediatamente anterior ao atingimento da idade mínima ou ao requerimento administrativo (TESE FIRMADA NO TEMA 145)." .

<https://example.org/tcc/activity/classification-trf2-live-1> a prov:Activity, tcc:ClassificationActivity ;
  prov:used <https://example.org/tcc/decision/trf2-live-1>, <https://example.org/tcc/theme/5> ;
  prov:generated <https://example.org/tcc/analysis/trf2-live-1> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/gemini-flash-lite-latest> ;
  prov:wasInformedBy <https://example.org/tcc/run/run-20260604t135935z> .

<https://example.org/tcc/analysis/trf2-live-1> a tcc:AnalysisResult, prov:Entity ;
  tcc:temaTnu "5" ;
  tcc:consonancia "CONSONANCIA" ;
  tcc:validade "VALIDA" ;
  tcc:justificativa "A decisão trata de aposentadoria por idade rural e a necessidade de comprovação de atividade campesina no período de carência, alinhando-se à tese firmada no Tema 5 da TNU (que remete ao Tema 145/TNU), que exige o exercício da atividade rural no período imediatamente anterior ao requerimento ou ao atingimento da idade." ;
  tcc:aboutDecision <https://example.org/tcc/decision/trf2-live-1> ;
  tcc:aboutTheme <https://example.org/tcc/theme/5> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/classification-trf2-live-1> .

<https://example.org/tcc/activity/draft-generation-trf2-live-1> a prov:Activity, tcc:DraftGenerationActivity ;
  prov:used <https://example.org/tcc/analysis/trf2-live-1>, <https://example.org/tcc/decision/trf2-live-1>, <https://example.org/tcc/theme/5> ;
  prov:generated <https://example.org/tcc/draft/trf2-live-1-negar-seguimento> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/pipeline> ;
  prov:wasInformedBy <https://example.org/tcc/activity/classification-trf2-live-1> .

<https://example.org/tcc/draft/trf2-live-1-negar-seguimento> a tcc:LegalDraft, prov:Entity ;
  tcc:action "NEGAR_SEGUIMENTO" ;
  tcc:texPath "outputs/documents/TRF2-LIVE-1-NEGAR_SEGUIMENTO.tex" ;
  tcc:pdfPath "outputs/documents/TRF2-LIVE-1-NEGAR_SEGUIMENTO.pdf" ;
