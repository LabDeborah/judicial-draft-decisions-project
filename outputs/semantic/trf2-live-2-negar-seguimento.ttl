@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix tcc: <https://example.org/tcc/ontology#> .

<https://example.org/tcc/run/run-20260604t135935z> a prov:Activity, tcc:PipelineRun .

<https://example.org/tcc/agent/pipeline> a prov:Agent, tcc:SoftwarePipeline .

<https://example.org/tcc/agent/gemini-flash-lite-latest> a prov:Agent, tcc:LargeLanguageModel ;
  dcterms:title "gemini-flash-lite-latest" ;
  tcc:analysisStrategy "gemini" .

<https://example.org/tcc/decision/trf2-live-2> a tcc:LegalDecision, prov:Entity ;
  tcc:decisionId "TRF2-LIVE-2" ;
  tcc:numeroProcesso "5002089-88.2023.4.02.5115" ;
  tcc:assuntos "DIREITO PREVIDENCIÁRIO. APELAÇÃO CÍVEL. APOSENTADORIA POR IDADE RURAL. REGIME DE ECONOMIA FAMILIAR. INÍCIO DE PROVA MATERIAL CORROBORADO POR PROVA TESTEMUNHAL. EXERCÍCIO DE ATIVIDADE URBANA DE FORMA DESCONTÍNUA. EFEITOS FINANCEIROS. FIXAÇÃO A PARTIR DA CITAÇÃO. RECURSO PARCIALMENTE PROVIDO. I. CASO EM EXAME 1. Apelação cível interposta pelo INSS contra sentença que julgou procedente pedido de concessão de aposentador" .

<https://example.org/tcc/theme/5> a tcc:TnuTheme, prov:Entity ;
  tcc:temaNumero "5" ;
  tcc:teseFirmada "Para a obtenção de aposentadoria por idade rural, é indispensável o exercício e a demonstração da atividade campesina correspondente à carência no período imediatamente anterior ao atingimento da idade mínima ou ao requerimento administrativo (TESE FIRMADA NO TEMA 145)." .

<https://example.org/tcc/activity/classification-trf2-live-2> a prov:Activity, tcc:ClassificationActivity ;
  prov:used <https://example.org/tcc/decision/trf2-live-2>, <https://example.org/tcc/theme/5> ;
  prov:generated <https://example.org/tcc/analysis/trf2-live-2> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/gemini-flash-lite-latest> ;
  prov:wasInformedBy <https://example.org/tcc/run/run-20260604t135935z> .

<https://example.org/tcc/analysis/trf2-live-2> a tcc:AnalysisResult, prov:Entity ;
  tcc:temaTnu "5" ;
  tcc:consonancia "CONSONANCIA" ;
  tcc:validade "VALIDA" ;
  tcc:justificativa "A decisão aborda a aposentadoria por idade rural e o regime de economia familiar, alinhando-se ao entendimento consolidado no Tema 5 da TNU (e Tema 145/STJ) sobre a necessidade de comprovação da atividade rural no período imediatamente anterior ao requerimento ou atingimento da idade." ;
  tcc:aboutDecision <https://example.org/tcc/decision/trf2-live-2> ;
  tcc:aboutTheme <https://example.org/tcc/theme/5> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/classification-trf2-live-2> .

<https://example.org/tcc/activity/draft-generation-trf2-live-2> a prov:Activity, tcc:DraftGenerationActivity ;
  prov:used <https://example.org/tcc/analysis/trf2-live-2>, <https://example.org/tcc/decision/trf2-live-2>, <https://example.org/tcc/theme/5> ;
  prov:generated <https://example.org/tcc/draft/trf2-live-2-negar-seguimento> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/pipeline> ;
  prov:wasInformedBy <https://example.org/tcc/activity/classification-trf2-live-2> .

<https://example.org/tcc/draft/trf2-live-2-negar-seguimento> a tcc:LegalDraft, prov:Entity ;
  tcc:action "NEGAR_SEGUIMENTO" ;
  tcc:texPath "outputs/documents/TRF2-LIVE-2-NEGAR_SEGUIMENTO.tex" ;
  tcc:pdfPath "outputs/documents/TRF2-LIVE-2-NEGAR_SEGUIMENTO.pdf" ;
  tcc:generatedFromDecision <https://example.org/tcc/decision/trf2-live-2> ;
  tcc:generatedFromAnalysis <https://example.org/tcc/analysis/trf2-live-2> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/draft-generation-trf2-live-2> .
