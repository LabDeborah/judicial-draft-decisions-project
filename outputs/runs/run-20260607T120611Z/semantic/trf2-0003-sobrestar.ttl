@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix tcc: <https://example.org/tcc/ontology#> .

<https://example.org/tcc/run/run-20260607t120611z> a prov:Activity, tcc:PipelineRun .

<https://example.org/tcc/agent/pipeline> a prov:Agent, tcc:SoftwarePipeline .

<https://example.org/tcc/agent/local-text-similarity> a prov:Agent, tcc:LocalClassifier ;
  dcterms:title "local-text-similarity" ;
  tcc:analysisStrategy "local" .

<https://example.org/tcc/decision/trf2-0003> a tcc:LegalDecision, prov:Entity ;
  tcc:decisionId "TRF2-0003" ;
  tcc:numeroProcesso "5000003-00.2025.4.02.5001" ;
  tcc:assuntos "Beneficio assistencial e renda familiar per capita" .

<https://example.org/tcc/theme/369> a tcc:TnuTheme, prov:Entity ;
  tcc:temaNumero "369" ;
  tcc:teseFirmada "" .

<https://example.org/tcc/activity/classification-trf2-0003> a prov:Activity, tcc:ClassificationActivity ;
  prov:used <https://example.org/tcc/decision/trf2-0003>, <https://example.org/tcc/theme/369> ;
  prov:generated <https://example.org/tcc/analysis/trf2-0003> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/local-text-similarity> ;
  prov:wasInformedBy <https://example.org/tcc/run/run-20260607t120611z> .

<https://example.org/tcc/analysis/trf2-0003> a tcc:AnalysisResult, prov:Entity ;
  tcc:temaTnu "369" ;
  tcc:consonancia "NAO_APLICAVEL" ;
  tcc:validade "VALIDA" ;
  tcc:justificativa "Tema 369 selecionado por semelhanca de assunto." ;
  tcc:aboutDecision <https://example.org/tcc/decision/trf2-0003> ;
  tcc:aboutTheme <https://example.org/tcc/theme/369> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/classification-trf2-0003> .

<https://example.org/tcc/activity/draft-generation-trf2-0003> a prov:Activity, tcc:DraftGenerationActivity ;
  prov:used <https://example.org/tcc/analysis/trf2-0003>, <https://example.org/tcc/decision/trf2-0003>, <https://example.org/tcc/theme/369> ;
  prov:generated <https://example.org/tcc/draft/trf2-0003-sobrestar> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/pipeline> ;
  prov:wasInformedBy <https://example.org/tcc/activity/classification-trf2-0003> .

<https://example.org/tcc/draft/trf2-0003-sobrestar> a tcc:LegalDraft, prov:Entity ;
  tcc:action "SOBRESTAR" ;
  tcc:texPath "outputs/runs/run-20260607T120611Z/documents/TRF2-0003-SOBRESTAR.tex" ;
  tcc:pdfPath "outputs/runs/run-20260607T120611Z/documents/TRF2-0003-SOBRESTAR.pdf" ;
  tcc:generatedFromDecision <https://example.org/tcc/decision/trf2-0003> ;
  tcc:generatedFromAnalysis <https://example.org/tcc/analysis/trf2-0003> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/draft-generation-trf2-0003> .
