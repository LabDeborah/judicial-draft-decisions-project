    rdfs:label "Tema 32 - Julgado"@pt-BR .

tese:32
    a ors:Thesis, prov:Entity ;
    rdfs:label "Theme 32 Thesis"@pt-BR ;
    ors:description "Certidão de óbito configura início de prova material para caracterização da atividade rural, para fins de pensão por morte."@pt-BR ;
    ors:hasTheme tema:32 .

jdd:theme-catalog-4b630ade-eed4-5c29-9c4a-54e4ba6a1093 prov:hadMember tema:32 .

tema:33
    a ors:Theme, prov:Entity ;
    ors:themeNumber "33" ;
    rdfs:label "Tema 33 - Julgado"@pt-BR .

tese:33
    a ors:Thesis, prov:Entity ;
    rdfs:label "Theme 33 Thesis"@pt-BR ;
    ors:description "A habitualidade e permanência da exposição ao agente nocivo ruído, devidamente comprovadas por laudo pericial, presumem-se no caso de segurado contribuinte individual empresário."@pt-BR ;
    ors:hasTheme tema:33 .

