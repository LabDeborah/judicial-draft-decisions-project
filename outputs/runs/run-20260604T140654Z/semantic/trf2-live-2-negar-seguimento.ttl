@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix tcc: <https://example.org/tcc/ontology#> .

<https://example.org/tcc/run/run-20260604t140654z> a prov:Activity, tcc:PipelineRun .

<https://example.org/tcc/agent/pipeline> a prov:Agent, tcc:SoftwarePipeline .

<https://example.org/tcc/agent/local-text-similarity> a prov:Agent, tcc:LocalClassifier ;
  dcterms:title "local-text-similarity" ;
  tcc:analysisStrategy "local" .

<https://example.org/tcc/decision/trf2-live-2> a tcc:LegalDecision, prov:Entity ;
  tcc:decisionId "TRF2-LIVE-2" ;
  tcc:numeroProcesso "5000693-03.2025.4.02.9999" ;
  tcc:assuntos "DIREITO PREVIDENCIÁRIO. APELAÇÃO CÍVEL. APOSENTADORIA RURAL POR IDADE. SEGURADA ESPECIAL. REGIME DE ECONOMIA FAMILIAR. EXERCÍCIO DE ATIVIDADE URBANA POR CÔNJUGE. DIMENSÃO DA PROPRIEDADE. INÍCIO DE PROVA MATERIAL CORROBORADO POR PROVA TESTEMUNHAL. COISA JULGADA AFASTADA. CONSECTÁRIOS LEGAIS. RECURSO PARCIALMENTE PROVIDO. I. CASO EM EXAME 1. Apelação cível interposta pelo INSS contra sentença que julgou procedente o pe" .

<https://example.org/tcc/theme/2> a tcc:TnuTheme, prov:Entity ;
  tcc:temaNumero "2" ;
  tcc:teseFirmada "No caso de aposentadoria por idade rural, a certidão de casamento vale como início de prova material, ainda que extemporânea." .

<https://example.org/tcc/activity/classification-trf2-live-2> a prov:Activity, tcc:ClassificationActivity ;
  prov:used <https://example.org/tcc/decision/trf2-live-2>, <https://example.org/tcc/theme/2> ;
  prov:generated <https://example.org/tcc/analysis/trf2-live-2> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/local-text-similarity> ;
  prov:wasInformedBy <https://example.org/tcc/run/run-20260604t140654z> .

<https://example.org/tcc/analysis/trf2-live-2> a tcc:AnalysisResult, prov:Entity ;
  tcc:temaTnu "2" ;
  tcc:consonancia "CONSONANCIA" ;
  tcc:validade "VALIDA" ;
  tcc:justificativa "Tema 2 selecionado por semelhanca de assunto." ;
  tcc:aboutDecision <https://example.org/tcc/decision/trf2-live-2> ;
  tcc:aboutTheme <https://example.org/tcc/theme/2> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/classification-trf2-live-2> .

<https://example.org/tcc/activity/draft-generation-trf2-live-2> a prov:Activity, tcc:DraftGenerationActivity ;
  prov:used <https://example.org/tcc/analysis/trf2-live-2>, <https://example.org/tcc/decision/trf2-live-2>, <https://example.org/tcc/theme/2> ;
  prov:generated <https://example.org/tcc/draft/trf2-live-2-negar-seguimento> ;
  prov:wasAssociatedWith <https://example.org/tcc/agent/pipeline> ;
  prov:wasInformedBy <https://example.org/tcc/activity/classification-trf2-live-2> .

<https://example.org/tcc/draft/trf2-live-2-negar-seguimento> a tcc:LegalDraft, prov:Entity ;
  tcc:action "NEGAR_SEGUIMENTO" ;
  tcc:texPath "outputs/runs/run-20260604T140654Z/documents/TRF2-LIVE-2-NEGAR_SEGUIMENTO.tex" ;
  tcc:pdfPath "outputs/runs/run-20260604T140654Z/documents/TRF2-LIVE-2-NEGAR_SEGUIMENTO.pdf" ;
  tcc:generatedFromDecision <https://example.org/tcc/decision/trf2-live-2> ;
  tcc:generatedFromAnalysis <https://example.org/tcc/analysis/trf2-live-2> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/draft-generation-trf2-live-2> .
