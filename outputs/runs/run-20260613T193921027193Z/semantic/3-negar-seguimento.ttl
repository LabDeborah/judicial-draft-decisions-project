<https://example.org/tcc/run/run-20260613t193921027193z> a prov:Activity, tcc:PipelineRun .

<https://example.org/tcc/agent/pipeline> a prov:Agent, tcc:SoftwarePipeline .

<https://example.org/tcc/agent/local-text-similarity> a prov:Agent, tcc:LocalClassifier ;
  dcterms:title "local-text-similarity" ;
  tcc:analysisStrategy "local" .

<http://purl.org/nemo/tres/3> a ors:Decision, prov:Entity ;
  ors:decisionNumber "3" ;
  ors:subject "Servidores Inativos, Contribuições Previdenciárias, Contribuições, DIREITO TRIBUTÁRIO" ;
  dcterms:identifier "5019643-10.2025.4.02.5101" .

<http://purl.org/nemo/tnu/1> a ors:Theme, prov:Entity ;
  ors:theme "1" ;
  ors:themeThesis "O valor da aposentadoria por invalidez e do auxílio-doença, bem como das pensões destes derivados ou calculadas com base no art. 75, da Lei n. 8.213/91, será obtido, na forma do art. 29, II, do mesmo diploma, por meio da média aritmética simples dos 80% maiores salários de contribuição, considerado todo o período contributivo, independentemente do momento de inscrição do segurado e do número de contribuições mensais do período contributivo." ;
  dcterms:description "Saber qual a forma de cálculo da aposentadoria por invalidez, do auxílio-doença e pensões derivadas, em momento antecedente à edição da Lei n. 9.876/99." .

<https://example.org/tcc/activity/classification-3> a prov:Activity, tcc:ClassificationActivity ;
  prov:used <http://purl.org/nemo/tres/3>, <http://purl.org/nemo/tnu/1> ;
  prov:generated <https://example.org/tcc/analysis/3> ;
