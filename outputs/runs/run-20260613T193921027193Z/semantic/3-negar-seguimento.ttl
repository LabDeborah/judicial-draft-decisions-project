<https://example.org/tcc/analysis/3> a tcc:AnalysisResult, prov:Entity ;
  tcc:selectedThemeCode "1" ;
  tcc:consonancia "CONSONANCIA" ;
  tcc:validade "VALIDA" ;
  tcc:justificativa "Tema 1 selecionado por semelhanca de assunto." ;
  tcc:aboutDecision <http://purl.org/nemo/tres/3> ;
  tcc:aboutTheme <http://purl.org/nemo/tnu/1> ;
  prov:wasGeneratedBy <https://example.org/tcc/activity/classification-3> .

<https://example.org/tcc/activity/draft-generation-3> a prov:Activity, tcc:DraftGenerationActivity ;
