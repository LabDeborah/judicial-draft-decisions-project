<http://purl.org/nemo/tnu/50> a ors:Theme, prov:Entity ;
  ors:theme "50" ;
  ors:themeThesis "A contribuição previdenciária dos militares inativos e pensionistas deve incidir sobre o total das parcelas que compõem os proventos da inatividade, não havendo direito à imunidade conferida aos segurados do RGPS e servidores." ;
  dcterms:identifier "50" ;
  dcterms:description "Saber se se aplica imunidade tributária sobre proventos de aposentadoria e pensão aos servidores militares aposentados e seus pensionistas." ;
