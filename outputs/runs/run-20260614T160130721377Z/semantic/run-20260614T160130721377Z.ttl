<http://purl.org/nemo/tnu/49> a ors:Theme, prov:Entity ;
  ors:theme "49" ;
  ors:themeThesis "Não se aplica a taxa progressiva de juros às contas vinculadas ao FGTS de trabalhadores qualificados como avulsos." ;
  dcterms:identifier "49" ;
  dcterms:description "Saber se o trabalhador avulso tem direito à aplicação da taxa de juros progressivos nas contas do FGTS." ;
