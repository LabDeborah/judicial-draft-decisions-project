  dcterms:identifier "5006521-55.2024.4.02.5103" .

<http://purl.org/nemo/tnu/92> a ors:Theme, prov:Entity ;
  ors:theme "92" ;
  ors:themeThesis "É devido o pagamento de meia diária ao servidor que, afastado de sua sede de serviço, tiver despesas extraordinárias tais como alimentação, deslocamento e hospedagem, custeadas com recursos públicos." ;
  dcterms:description "Saber se o fornecimento de hospedagem e alimentação pelo ente público, sem a ocorrência de despesas com deslocamento urbano, afasta o direito ao recebimento das diárias por servidor público." .

