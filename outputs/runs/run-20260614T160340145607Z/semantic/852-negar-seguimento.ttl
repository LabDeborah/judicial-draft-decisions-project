  dcterms:title "local-text-similarity" ;
  tcc:analysisStrategy "local" .

<http://purl.org/nemo/tres/852> a ors:Decision, prov:Entity ;
  ors:decisionNumber "852" ;
  ors:subject "Reajuste de Remuneração, Soldo, Proventos ou Pensão, Militar, DIREITO ADMINISTRATIVO E OUTRAS MATÉRIAS DE DIREITO PÚBLICO" ;
  dcterms:identifier "5081352-80.2024.4.02.5101" .

<http://purl.org/nemo/tnu/212> a ors:Theme, prov:Entity ;
  ors:theme "212" ;
  ors:themeThesis "O militar promovido tem direito ao recebimento integral do auxílio-fardamento no valor de um soldo do novo posto ou graduação, mesmo que tenha recebido a mesma vantagem anteriormente dentro do prazo de um ano, sendo ilegal a limitação imposta pelo art. 61 do Decreto n. 4.307/2002." ;
  dcterms:description "Saber se o militar promovido no período de até um ano após fazer jus ao auxílio-fardamento, tem direito somente à diferença entre o valor do auxílio referente ao novo posto ou graduação e o efetivamente recebido, nos termos do art. 61, do Decreto nº 4.307/2002." .

