<https://example.org/tcc/draft/trf2-live-3-negar-seguimento> a tcc:LegalDraft, prov:Entity ;
  tcc:action "NEGAR_SEGUIMENTO" ;
  tcc:texPath "outputs/runs/run-20260608T181405241752Z/documents/TRF2-LIVE-3-NEGAR_SEGUIMENTO.tex" ;
