  tcc:analysisStrategy "local" .

<http://purl.org/nemo/tres/1502> a ors:Decision, prov:Entity ;
  ors:decisionNumber "1502" ;
  ors:subject "Aposentadoria por Tempo de Contribuição (Art. 55/6), Benefícios em Espécie, DIREITO PREVIDENCIÁRIO" ;
  dcterms:identifier "5066888-51.2024.4.02.5101" .

<http://purl.org/nemo/tnu/358> a ors:Theme, prov:Entity ;
  ors:theme "358" ;
  ors:themeThesis "1. Tempo de contribuição e carência são institutos distintos. 2. Carência condiz com contribuições tempestivas. 3. O art. 18 da EC 103/2019 não dispensa a carência para a concessão de aposentadoria." ;
  dcterms:description "Saber se, para fins de concessão de aposentadoria por idade urbana com DER após a EC 103/2019, permanece a necessidade de cumprimento do requisito da carência, particularmente para quem precisa usar a regra de transição do art. 18 da EC 103, ou se a regra de transição prevista no art. 18, da EC 103/19 não exige mais tal requisito (bastando ao beneficiário preencher, cumulativamente, os requisitos \"idade\" e \"tempo de contribuição\"), de forma que as contribuições recolhidas em atraso pelo contribuinte individual possam ser computados como tempo de contribuição (ainda que este tenha perdido a qualidade de segurado)." .

